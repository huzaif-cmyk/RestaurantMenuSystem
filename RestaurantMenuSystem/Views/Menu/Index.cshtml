@{
}
@model IEnumerable<RestaurantSystem.Models.MenuItem>

<h2 class="text-center menu-title">restaurant menu</h2>

<div class="d-flex justify-content-center gap-2 mb-4 mt-3">
    <a asp-action="index" asp-route-category="" class="btn btn-orange">all</a>
    <a asp-action="index" asp-route-category="starter" class="btn btn-outline-orange">starter</a>
    <a asp-action="index" asp-route-category="main course" class="btn btn-outline-orange">main course</a>
    <a asp-action="index" asp-route-category="desserts" class="btn btn-outline-orange">dessert</a>
</div>

<div class="container">
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm food-card">
                    <div class="card-body text-center">
                        <h5 class="card-title text-capitalize" style="color: #444;">@item.Name</h5>
                        <p class="text-muted small">@item.Category</p>
                        <p class="fw-bold price-tag">rs. @item.Price.ToString("0.00")</p>
                        <a asp-action="details" asp-route-id="@item.Id" class="btn btn-sm btn-orange w-100">view details</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>